---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../lib/url';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toISOString().slice(0, 7); // YYYY-MM
---
<Base title="Chris Schroedinger — ex-poker pro turned AI agentic engineer" current="home">
  <h1>ex-poker player, turned AI agentic engineer</h1>

  <div class="prose" style="margin-top: 1.2rem;">
    <p class="muted">
      I'm Chris. I used to make a living at the poker tables —
      decisions under uncertainty, risk management, and staying level
      while variance does its thing. Now I apply the same discipline to a
      different game: engineering with AI agents.
    </p>
    <p class="muted">
      What's ahead: I'm building tools and processes with AI and AI agents
      that save time and energy, so the human can focus on whats important.
    </p>
  </div>

  <h2 class="mono">writing</h2>
  {posts.length > 0 ? (
    <ul class="item-list">
      {posts.map((post) => (
        <li>
          <span class="when mono">{fmt(post.data.date)}</span>
          <span class="what"><a href={url(`/blog/${post.id}/`)}>{post.data.title}</a></span>
        </li>
      ))}
    </ul>
  ) : (
    <p class="muted">Nothing yet.</p>
  )}
  <p class="small" style="margin-top: 0.8rem;"><a class="mono" href={url('/blog')}>all posts →</a></p>
</Base>
