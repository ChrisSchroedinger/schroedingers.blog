---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { url } from '../lib/url';
import portrait from '../assets/schroedinger.webp';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toISOString().slice(0, 7); // YYYY-MM
---
<Base title="Chris Schroedinger — building stuff" current="home">
  <h1>Hi, I'm Chris</h1>

  <div class="prose" style="margin-top: 1.2rem;">
    <p class="muted">
      I'm learning to build stuff with AI.
    </p>
  </div>

  <Image
    src={portrait}
    alt="Illustration of Chris at his desk, a terminal on one monitor and an agent workflow on the other"
    class="about-pic"
    width={1344}
    loading="eager"
  />

  <h2 class="mono">writing</h2>
  {posts.length > 0 ? (
    <ul class="item-list">
      {posts.map((post) => (
        <li>
          <span class="when mono">{fmt(post.data.date)}</span>
          <span class="what"><a href={url(`/blog/${post.id}/`)}>{post.data.title}</a></span>
        </li>
      ))}
    </ul>
  ) : (
    <p class="muted">Nothing yet.</p>
  )}
  <p class="small" style="margin-top: 0.8rem;"><a class="mono" href={url('/blog')}>all posts →</a></p>
</Base>
