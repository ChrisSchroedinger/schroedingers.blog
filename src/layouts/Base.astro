---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current?: string;
}
const { title, description = 'Chris Schroedinger — building local-first tools for the AI-augmented life.', current = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="Chris Schroedinger" href="/rss.xml" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='13' font-size='13'%3E%E2%96%B8%3C/text%3E%3C/svg%3E" />
</head>
<body>
  <div class="page">
    <header class="site-head mono">
      <a class="wordmark" href="/">chris schroedinger</a>
      <nav>
        <a href="/" aria-current={current === 'home' ? 'page' : undefined}>about</a>
        <a href="/blog" aria-current={current === 'blog' ? 'page' : undefined}>writing</a>
        <a href="https://github.com/ChrisSchroedinger">github</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-foot mono">
      <span>© 2026 Chris Schroedinger</span>
      <span><a href="/rss.xml">rss</a> · <a href="https://github.com/ChrisSchroedinger/chrisschroedinger.github.io">site source</a></span>
    </footer>
  </div>
</body>
</html>
